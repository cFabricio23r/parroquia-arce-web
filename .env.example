# Copiar los valores exactos desde el dashboard de Supabase -> Connect.
# No reconstruir los hostnames a mano: el prefijo del pooler (aws-0 / aws-1 ...)
# varia por proyecto, y equivocarse da errores de conexion dificiles de leer.

# Runtime: SIEMPRE el pooler de Supabase en modo transaccion (puerto 6543).
DATABASE_URL=postgresql://postgres.REF:PASS@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Solo para migraciones, desde maquina local o CI. Es IPv6-only: NO cargarla en Vercel.
DATABASE_URL_DIRECT=postgresql://postgres:PASS@db.REF.supabase.co:5432/postgres

PAYLOAD_SECRET=generar-con-crypto-randomBytes-32

# Supabase Storage (S3-compatible)
S3_BUCKET=media
S3_REGION=us-east-1
S3_ENDPOINT=https://REF.supabase.co/storage/v1/s3
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
